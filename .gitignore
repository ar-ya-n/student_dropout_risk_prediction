# Data and ML Models
# Ignore data files to avoid pushing sensitive or large datasets
data/*.csv
data/*.xlsx
data/*.json
data/raw/
data/processed/
# Allow tracking of data directory structure if needed, but typically not raw data files
!data/.gitkeep
!data/README.md

# Ignore saved models (large files)
models/*.joblib
models/*.pt
models/*.h5
models/*.onnx
models/saved_models/*.pkl
# Allow the trained artifact needed by the API
!models/saved_models/best_model.pkl

